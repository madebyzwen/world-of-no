#!/bin/sh

set -eu

PROJECT_ROOT=$(git rev-parse --show-toplevel)

if ! git diff --quiet -- .htaccess robots.txt sitemap.xml index.html assets data; then
  echo "Website source files have unstaged changes." >&2
  echo "Stage them before committing so dist matches the commit." >&2
  exit 1
fi

"$PROJECT_ROOT/scripts/build-dist.sh"
git add -A -- dist
