# World of No — built by Sven Hüttmann
# Used by Apache webspaces. GitHub Pages safely ignores this file.

DirectoryIndex index.html
AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  AddType application/json .json
  AddType application/xml .xml
  AddType audio/mpeg .mp3
  AddType image/svg+xml .svg
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 1 hour"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  <FilesMatch "^(index\.html|robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
